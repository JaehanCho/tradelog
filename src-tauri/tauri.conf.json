{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TradeLog",
  "version": "0.1.7",
  "identifier": "com.tradelog.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TradeLog",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        },
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "public.app-category.finance",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/JaehanCho/tradelog/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2NDdCNEQwMDNFMENFQ0UKUldUT3p1QUQwTFJIRm9mRldnN2Z6ZW85RHNCWnRqTzk2NFVwNkM1Znl2WTEzRzViUTQzcFpCQm4K"
    }
  }
}
